# CreatorCanon environment template.
# Copy to `.env` for preview/test/prod. Local smoke writes `.env.local`.

NODE_ENV=development

# Public browser env
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HUB_ROOT_DOMAIN=creatorcanon.local
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Postgres / Neon
DATABASE_URL=postgres://postgres:postgres@localhost:5432/creatorcanon
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT=10

# Artifact storage: local for deterministic dev, r2 for alpha/prod
ARTIFACT_STORAGE=r2
LOCAL_ARTIFACT_DIR=.local/artifacts
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=creatorcanon-dev
R2_PUBLIC_BASE_URL=https://cdn.creatorcanon.local

# Redis / Upstash REST URL
REDIS_URL=https://example.upstash.io

# Auth.js and Google OAuth
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_EMAIL=

# YouTube OAuth client with YouTube scopes
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=

# Stripe. Private-alpha smoke expects sk_test_ and whsec_ values.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional email and observability
RESEND_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=creatorcanon-web
SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1

# Trigger.dev. If unavailable, app-side local fallback can run the current pipeline.
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=
TRIGGER_API_URL=https://api.trigger.dev

# Hosted dispatch mode: use `worker` for the binary-capable Railway/container worker.
PIPELINE_DISPATCH_MODE=inprocess

# Optional operator extraction overrides for real YouTube audio fallback.
AUDIO_EXTRACTION_YTDLP_BIN=yt-dlp
AUDIO_EXTRACTION_FFMPEG_BIN=ffmpeg
AUDIO_EXTRACTION_CHALLENGE_RUNTIME_BIN=deno

# Private-alpha smoke. Set before running `pnpm smoke:alpha`.
ALPHA_SMOKE_RUN_ID=
ALPHA_SMOKE_ACTOR_USER_ID=
ALPHA_HOSTED_URL_CHECK=false
ALPHA_AUDIO_EXTRACT_CONFIRM=false

# Seeded alpha E2E writes fixed demo rows/artifacts. Required for non-local DB/R2.
ALPHA_E2E_CONFIRM=false
