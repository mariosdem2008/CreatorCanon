# ---------------------------------------------------------------------------
# CreatorCanon — environment template
# Copy to `.env` at the repo root. Each app reads from this file via dotenv.
# Full wiring lands in ticket 0.6. Keys listed now so the schema is stable.
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- Public (exposed to the browser) ----------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HUB_ROOT_DOMAIN=creatorcanon.local
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Postgres (Neon) --------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/atlas
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT=10

# --- Local smoke artifacts --------------------------------------------------
ARTIFACT_STORAGE=r2
LOCAL_ARTIFACT_DIR=.local/artifacts

# --- Redis (Upstash in prod, local docker in dev) ---------------------------
REDIS_URL=redis://localhost:6379

# --- Cloudflare R2 ----------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=creatorcanon-dev
R2_PUBLIC_BASE_URL=https://cdn.creatorcanon.local

# --- Auth.js v5 + Google OAuth ---------------------------------------------
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_EMAIL=

# --- YouTube OAuth (separate client — asks for YT scopes, not sign-in only)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=

# --- AI providers -----------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=

# --- Observability ----------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=creatorcanon-web

# --- Trigger.dev ------------------------------------------------------------
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
