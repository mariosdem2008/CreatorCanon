{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "cd ../.. && pnpm --filter @creatorcanon/web build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/credits/reconcile",
      "schedule": "0 3 * * *"
    }
  ]
}
