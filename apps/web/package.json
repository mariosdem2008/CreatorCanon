{
  "name": "@creatorcanon/web",
  "version": "0.0.0",
  "private": true,
  "description": "CreatorCanon Next.js 14 application — creator app, hub runtime, admin, marketing.",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
