{
  "name": "@creatorcanon/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Trigger.dev worker process — hosts the 16-stage pipeline tasks.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n queue,trigger -c blue,magenta \"tsx watch src/dev-server.ts\" \"trigger dev\"",
    "dev:queue": "tsx watch src/dev-server.ts",
    "start": "node --import tsx/esm src/dev-server.ts",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "smoke:trigger-dispatch": "tsx ./src/smoke-trigger-dispatch.ts",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bash -O globstar -c 'NODE_ENV=test node --import \"../../node_modules/.pnpm/tsx@4.19.1/node_modules/tsx/dist/loader.mjs\" --test src/**/*.test.ts'",
    "build": "echo 'worker: source-only, no build'",
    "clean": "rm -rf dist .turbo .trigger"
  },
  "dependencies": {
    "@creatorcanon/adapters": "workspace:*",
    "@creatorcanon/core": "workspace:*",
    "@creatorcanon/cost-ledger": "workspace:*",
    "@creatorcanon/db": "workspace:*",
    "@creatorcanon/pipeline": "workspace:*",
    "@sentry/node": "8.33.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/sdk-node": "0.53.0",
    "@trigger.dev/sdk": "4.4.4",
    "@trigger.dev/core": "4.4.4",
    "tsx": "4.19.1"
  },
  "devDependencies": {
    "@creatorcanon/config": "workspace:*",
    "@types/node": "20.14.10",
    "trigger.dev": "4.4.4",
    "typescript": "5.6.2"
  }
}
