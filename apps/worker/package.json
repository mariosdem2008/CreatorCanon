{
  "name": "@atlas/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Trigger.dev worker process — hosts the 16-stage pipeline tasks.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/dev-server.ts",
    "start": "node --import tsx/esm src/dev-server.ts",
    "trigger:dev": "trigger dev",
    "trigger:deploy": "trigger deploy",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'worker: no tests yet'",
    "build": "echo 'worker: source-only, no build'",
    "clean": "rm -rf dist .turbo .trigger"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "@atlas/cost-ledger": "workspace:*",
    "@atlas/db": "workspace:*",
    "@atlas/pipeline": "workspace:*",
    "@sentry/node": "8.33.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/sdk-node": "0.53.0"
  },
  "devDependencies": {
    "@atlas/config": "workspace:*",
    "@types/node": "20.14.10",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
