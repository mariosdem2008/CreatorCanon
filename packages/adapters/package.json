{
  "name": "@creatorcanon/adapters",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript client shells and strict interface contracts for every external service the product depends on (R2, Redis, OpenAI, Gemini, Stripe, YouTube, Resend).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./r2": "./src/r2/client.ts",
    "./r2/keys": "./src/r2/keys.ts",
    "./redis": "./src/redis/client.ts",
    "./redis/rate-limit": "./src/redis/rate-limit.ts",
    "./openai": "./src/openai/client.ts",
    "./gemini": "./src/gemini/client.ts",
    "./stripe": "./src/stripe/client.ts",
    "./youtube": "./src/youtube/client.ts",
    "./resend": "./src/resend/client.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bash -O globstar -c 'node --import \"../../node_modules/.pnpm/tsx@4.19.1/node_modules/tsx/dist/loader.mjs\" --test src/**/*.test.ts'",
    "build": "echo 'adapters: source-only, no build'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@creatorcanon/core": "workspace:*",
    "@aws-sdk/client-s3": "3.654.0",
    "google-auth-library": "9.14.1",
    "@aws-sdk/s3-request-presigner": "3.654.0",
    "@google/generative-ai": "0.21.0",
    "@upstash/redis": "1.34.0",
    "googleapis": "143.0.0",
    "openai": "4.61.0",
    "resend": "4.0.0",
    "stripe": "16.12.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@creatorcanon/config": "workspace:*",
    "typescript": "5.6.2"
  }
}
