{
  "name": "@creatorcanon/pipeline",
  "version": "0.0.0",
  "private": true,
  "description": "16-stage hybrid text+visual content pipeline. Stages, artifact contracts, idempotency keys.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./stages": "./src/stages/index.ts",
    "./contracts": "./src/contracts/index.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'pipeline: no tests yet'",
    "build": "echo 'pipeline: source-only, no build'",
    "smoke:local": "tsx ./src/smoke-local.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@creatorcanon/adapters": "workspace:*",
    "@creatorcanon/core": "workspace:*",
    "@creatorcanon/db": "workspace:*",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@creatorcanon/config": "workspace:*",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
