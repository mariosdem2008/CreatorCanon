{
  "name": "@creatorcanon/pipeline",
  "version": "0.0.0",
  "private": true,
  "description": "16-stage hybrid text+visual content pipeline. Stages, artifact contracts, idempotency keys.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./stages": "./src/stages/index.ts",
    "./contracts": "./src/contracts/index.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bash -O globstar -c 'NODE_ENV=test node --import \"../../node_modules/.pnpm/tsx@4.19.1/node_modules/tsx/dist/loader.mjs\" --test src/**/*.test.ts'",
    "build": "echo 'pipeline: source-only, no build'",
    "env:doctor": "tsx ./src/env-doctor.ts",
    "smoke:alpha": "tsx ./src/smoke-alpha.ts",
    "smoke:browser:local": "tsx ./src/smoke-browser-local.ts",
    "smoke:audio-fixtures": "tsx ./src/smoke-audio-fixtures.ts",
    "smoke:audio-publish": "tsx ./src/smoke-audio-publish.ts",
    "smoke:review-edit": "tsx ./src/smoke-review-edit.ts",
    "inspect:run": "tsx ./src/inspect-run.ts",
    "inspect:alpha-run": "tsx ./src/inspect-alpha-run.ts",
    "inspect:alpha-content": "tsx ./src/inspect-alpha-content.ts",
    "extract:alpha-audio": "tsx ./src/extract-alpha-audio.ts",
    "rescue:alpha-run": "tsx ./src/rescue-alpha-run.ts",
    "smoke:local": "tsx ./src/smoke-local.ts",
    "seed:audio-fixtures": "tsx ./src/seed-audio-fixtures.ts",
    "seed:alpha-audio-videos": "tsx ./src/seed-alpha-audio-videos.ts",
    "refresh:alpha-caption-status": "tsx ./src/refresh-alpha-caption-status.ts",
    "run:alpha:e2e": "tsx ./src/run-alpha-e2e.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@creatorcanon/adapters": "workspace:*",
    "@creatorcanon/core": "workspace:*",
    "@creatorcanon/cost-ledger": "workspace:*",
    "@creatorcanon/db": "workspace:*",
    "@google/generative-ai": "0.21.0",
    "@sentry/node": "8.33.1",
    "openai": "4.61.0",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.23.5"
  },
  "devDependencies": {
    "@creatorcanon/config": "workspace:*",
    "playwright": "1.56.1",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
