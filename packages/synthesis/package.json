{
  "name": "@creatorcanon/synthesis",
  "version": "0.1.0",
  "private": true,
  "description": "Product synthesis layer — composer agents that turn audit substrate into a typed ProductBundle.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./runner": "./src/runner.ts",
    "./composers/*": "./src/composers/*.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bash -O globstar -c 'NODE_ENV=test node --import \"../../node_modules/.pnpm/tsx@4.19.1/node_modules/tsx/dist/loader.mjs\" --test src/**/*.test.ts'",
    "build": "echo 'synthesis: source-only, no build'",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@creatorcanon/core": "workspace:*",
    "@creatorcanon/db": "workspace:*",
    "drizzle-orm": "0.33.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@creatorcanon/config": "workspace:*",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
