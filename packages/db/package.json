{
  "name": "@atlas/db",
  "version": "0.0.0",
  "private": true,
  "description": "Drizzle schema + client for the Atlas Postgres (with pgvector) database.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'db: no tests yet'",
    "build": "echo 'db: source-only, no build'",
    "generate": "drizzle-kit generate",
    "migrate": "tsx ./src/migrate.ts",
    "studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo drizzle/out"
  },
  "dependencies": {
    "@atlas/core": "workspace:*",
    "drizzle-orm": "0.33.0",
    "postgres": "3.4.4"
  },
  "devDependencies": {
    "@atlas/config": "workspace:*",
    "drizzle-kit": "0.24.2",
    "tsx": "4.19.1",
    "typescript": "5.6.2"
  }
}
