{
  "name": "channel-atlas",
  "version": "0.0.0",
  "private": true,
  "description": "Channel Atlas — creator archive productization SaaS (Hosted Knowledge Hubs from YouTube channels).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @atlas/db generate",
    "db:migrate": "pnpm --filter @atlas/db migrate",
    "db:studio": "pnpm --filter @atlas/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.6",
    "turbo": "2.1.2",
    "typescript": "5.6.2"
  }
}
